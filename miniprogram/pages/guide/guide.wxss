.container {
  padding: 12px 16px 32px;
  background: #f5f5f5;
  min-height: 100vh;
}

/* loading */
.loading {
  display: flex; justify-content: center; align-items: center;
  min-height: 60vh;
  font-size: 15px; color: #888;
}

/* celebrate */
.celebrate {
  background: #fff; border-radius: 16px; padding: 32px 20px;
  text-align: center; margin-top: 40px;
}
.celebrate-icon { font-size: 48px; display: block; margin-bottom: 12px; }
.celebrate-title { font-size: 22px; font-weight: 700; color: #059669; display: block; margin-bottom: 8px; }
.celebrate-desc { font-size: 15px; color: #333; display: block; margin-bottom: 12px; line-height: 1.6; }
.celebrate-reminder { font-size: 13px; color: #92400e; background: #fef3c7; border-radius: 8px; padding: 10px; display: block; margin-bottom: 20px; line-height: 1.5; }
.btn-home { background: #4f46e5; color: #fff; border: none; border-radius: 10px; padding: 14px; font-size: 16px; margin-top: 8px; }

/* step header */
.step-header { margin-bottom: 10px; }
.step-title { font-size: 12px; color: #888; display: block; margin-bottom: 2px; }
.page-name { font-size: 20px; font-weight: 700; color: #111; display: block; }

/* progress */
.progress-section { background: #fff; border-radius: 8px; padding: 10px 12px; margin-bottom: 10px; }
.progress-bar { height: 6px; background: #e0e0e0; border-radius: 3px; margin-bottom: 6px; overflow: hidden; }
.progress-fill { height: 100%; background: #4f46e5; border-radius: 3px; transition: width 0.3s; }
.progress-text { font-size: 12px; color: #666; }

/* site hint */
.site-hint { background: #eef2ff; border-radius: 8px; padding: 10px 12px; margin-bottom: 12px; font-size: 13px; color: #4338ca; line-height: 1.5; }
.site-url { font-weight: 600; text-decoration: underline; }

/* field card */
.field-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
.field-card { background: #fff; border-radius: 12px; padding: 14px; }
.field-label-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.field-label { font-size: 12px; color: #888; font-weight: 600; }
.field-section-tag { font-size: 10px; color: #4f46e5; background: #eef2ff; padding: 2px 8px; border-radius: 8px; }

.field-skipped { font-size: 14px; color: #92400e; }

.field-answer { background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; padding: 12px; margin-bottom: 8px; }
.answer-text { font-size: 20px; font-weight: 700; color: #15803d; font-family: monospace; display: block; line-height: 1.4; word-break: break-all; }
.answer-hint-zh { font-size: 12px; color: #888; display: block; margin-top: 4px; }

.field-actions { display: flex; justify-content: flex-end; }
.btn-done { background: #f5f5f5; color: #888; border: 1px solid #e0e0e0; border-radius: 20px; padding: 6px 16px; font-size: 13px; }
.btn-done-active { background: #f0fdf4; color: #15803d; border-color: #86efac; }

/* nav buttons */
.nav-actions { display: flex; gap: 12px; padding: 12px 0 24px; }
.btn-prev, .btn-next {
  flex: 1; border-radius: 10px; padding: 14px; font-size: 16px; font-weight: 600;
  text-align: center;
}
.btn-prev { background: #fff; color: #4f46e5; border: 1px solid #4f46e5; }
.btn-next { background: #4f46e5; color: #fff; border: none; }
.btn-disabled { opacity: 0.4; }
.nav-spacer { width: 0; }
