.container { padding: 16px; }
.header { background: #f0fdf4; border-radius: 12px; padding: 16px; margin-bottom: 16px; }
.title { font-size: 18px; font-weight: 700; color: #15803d; display: block; margin-bottom: 8px; }
.stats { display: flex; gap: 12px; }
.stat-done { font-size: 13px; color: #166534; background: #dcfce7; padding: 4px 10px; border-radius: 12px; }
.stat-pending { font-size: 13px; color: #92400e; background: #fef3c7; padding: 4px 10px; border-radius: 12px; }
.section { background: #fff; border-radius: 10px; margin-bottom: 12px; overflow: hidden; }
.section-title { display: block; background: #4f46e5; color: #fff; padding: 8px 12px; font-size: 12px; font-weight: 600; }
.entry { padding: 10px 12px; border-bottom: 1px solid #f5f5f5; }
.field-name { font-size: 11px; color: #888; display: block; margin-bottom: 2px; }
.answer-en { font-size: 14px; font-weight: 700; color: #111; font-family: monospace; display: block; }
.answer-zh { font-size: 11px; color: #666; }
.entry-pending { display: flex; justify-content: space-between; align-items: center; }
.pending-label { font-size: 12px; color: #f59e0b; }
.btn-save { background: #4f46e5; color: #fff; border: none; border-radius: 10px; padding: 14px; font-size: 15px; margin-top: 16px; }
.btn-guide { background: #059669; color: #fff; border: none; border-radius: 10px; padding: 14px; font-size: 15px; margin-top: 12px; }
